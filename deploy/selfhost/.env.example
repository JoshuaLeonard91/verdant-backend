# Self-host compose defaults.
# Copy this file to .env, then replace every local/example secret before starting
# a server that is reachable by anyone else.

COMPOSE_PROJECT_NAME=selfhost-chat

# The Rust server listens on RS_PORT first, then PORT, and defaults to 3001.
RS_PORT=3001
HOST_APP_PORT=3001

INSTANCE_NAME=Self-Host Chat
INSTANCE_MODE=standalone
INSTANCE_PUBLIC_URL=http://localhost:3001
INSTANCE_API_URL=http://localhost:3001
INSTANCE_WS_URL=ws://localhost:3001
INSTANCE_DOCS_URL=http://localhost:3001/docs
INSTANCE_TRUSTED_HOSTS=localhost,127.0.0.1
# Comma-separated proxy IPs/CIDRs allowed to supply do-connecting-ip.
# Leave empty for direct localhost compose. The generated Caddy droplet config
# sets this to loopback and overwrites do-connecting-ip before proxying.
TRUSTED_PROXY_CIDRS=

# Explicit browser origins only. Do not use wildcards in production.
CORS_ORIGIN=http://localhost:3001,http://localhost:5173,http://tauri.localhost,https://tauri.localhost,tauri://localhost
FRONTEND_URL=http://localhost:3001
MIN_CLIENT_VERSION=0.0.293

# Generate a cryptographically random value with at least 32 characters.
# The server refuses obvious placeholder JWT secrets at runtime.
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_32_CHARS_MIN

# Postgres owner/migration role. The official postgres image creates this role
# and database on first boot from a fresh volume.
POSTGRES_DB=appdb
POSTGRES_USER=db_owner
POSTGRES_PASSWORD=replace-with-owner-password
POSTGRES_APP_ROLE=app_runtime
POSTGRES_APP_LOGIN=app_runtime_login
POSTGRES_APP_PASSWORD=replace-with-different-app-password
DATABASE_POOL_SIZE=30

# Database role split:
# - DATABASE_URL and MIGRATION_DATABASE_URL use the owner/migration role.
# - DATABASE_APP_URL uses the separate POSTGRES_APP_LOGIN role created by
#   postgres/init/001-create-app-role.sh and granted to the NOLOGIN POSTGRES_APP_ROLE
#   role for RLS-constrained runtime access.
# - DATABASE_APP_URL must not equal DATABASE_URL.
DATABASE_URL=postgresql://db_owner:replace-with-owner-password@postgres:5432/appdb
MIGRATION_DATABASE_URL=postgresql://db_owner:replace-with-owner-password@postgres:5432/appdb
DATABASE_APP_URL=postgresql://app_runtime_login:replace-with-different-app-password@postgres:5432/appdb

REDIS_URL=redis://redis:6379

# Self-host capability and policy defaults.
BILLING_MODE=disabled
CONTENT_SCAN_PROVIDER=none
UPLOAD_POLICY=media_validation_only
PUBLIC_REGISTRATION_ENABLED=false
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_PROVIDER=disabled
INSTANCE_CAP_IMAGE_UPLOADS=true
INSTANCE_CAP_FILE_SHARING=true
INSTANCE_CAP_MESSAGE_ATTACHMENTS=true
INSTANCE_CAP_VOICE_CHAT=false
INSTANCE_CAP_VIDEO_STREAMING=false
INSTANCE_CAP_CROSS_SERVER_EMOJI=false
INSTANCE_CAP_ANIMATED_AVATAR=true
INSTANCE_CAP_ANIMATED_BANNER=true
INSTANCE_CAP_MEMBER_LIST_BANNER=true
INSTANCE_MAX_UPLOAD_BYTES=26214400
INSTANCE_MAX_VOICE_BITRATE=256000

# Required only when INSTANCE_MODE=linked or federated and account linking is
# enabled with FEDERATION_LINK_VERIFY_KEY_PEM. Self-hosts poll this official API
# origin for opaque proof-grant revocation status.
# ACCOUNT_LINK_OFFICIAL_API_ORIGIN=https://api.official.example.com

# MinIO provides the local S3-compatible object store.
MINIO_ROOT_USER=objectstore_admin
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=media-uploads
S3_ACCESS_KEY=objectstore_admin
S3_SECRET_KEY=replace-with-minio-root-password
# Optional S3 signing region. Leave unset for the bundled MinIO defaults unless
# your S3-compatible provider requires a fixed region.
# Single-VPS Garage installs generated by Verdant Operator use S3_REGION=garage.
# S3_REGION=garage
STORAGE_PATH_STYLE=true
# Public base URL used for profile, server, bot, emoji, and sticker media URLs. Message
# attachments must stay private in object storage and must only be served by the
# authenticated /api/media/attachments/{id} route.
#
# Local compose exposes MinIO only on localhost; production should use your
# HTTPS reverse proxy/CDN with public access limited to the media prefixes
# documented in docs/SELF_HOSTING.md.
CDN_BASE_URL=http://localhost:9000/media-uploads

# Optional LiveKit voice. Start it with:
#   docker compose --profile voice up -d
#
# LIVEKIT_URL is the public base WebSocket URL for LiveKit signaling. Desktop
# clients receive a localhost Rust proxy URL, but Rust validates and forwards to
# this base URL. Do not include credentials, query strings, or fragments. Use a
# publicly routable wss:// host outside local development.
# LIVEKIT_API_URL is the private/container URL used by server-rs RoomService calls.
# LIVEKIT_API_SECRET must be random, non-placeholder text at least 32 characters.
# These local defaults make `docker compose --profile voice config` render cleanly;
# replace them before enabling voice outside local testing.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_URL=http://livekit:7880
LIVEKIT_API_KEY=local-voice
LIVEKIT_API_SECRET=CHANGE_ME_RANDOM_LIVEKIT_SECRET_32_CHARS_MIN
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT=7882
